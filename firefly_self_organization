#cell 2
def order_parameter(phases):
    return np.abs(np.mean(np.exp(2j * np.pi * phases)))

def build_neighbors(N, M, r, periodic=True):  #r interaction radius; only nodes within distance ≤ r are neighbors
    """Return neighbor lists for each node in an N×M grid"""
    positions = np.array([(i, j) for i in range(N) for j in range(M)])
    neighbors = []
    for idx, (x, y) in enumerate(positions):
        dists = np.sqrt((positions[:,0] - x)**2 + (positions[:,1] - y)**2)
        if periodic:
            dx = np.minimum(np.abs(positions[:,0]-x), N - np.abs(positions[:,0]-x))
            dy = np.minimum(np.abs(positions[:,1]-y), M - np.abs(positions[:,1]-y))
            dists = np.sqrt(dx**2 + dy**2)
        nbrs = np.where((dists > 0) & (dists <= r))[0]
        neighbors.append(nbrs)
    return neighbors



#cell 3
def simulate_fireflies(N, M, r, CouplingValue, timestepsPerPeriod=100, total_periods=15,
                       periodic=True, seed=None, record_states=False):
    if seed is not None:
        np.random.seed(seed)
    
    n_nodes = N * M
    neighbors = build_neighbors(N, M, r, periodic=periodic)
    
    phases = np.random.rand(n_nodes)
    total_steps = timestepsPerPeriod * total_periods
    dt = 1.0 / timestepsPerPeriod
    R_t = []
    frames = []

    for t in range(total_steps):
        flashed = np.zeros(n_nodes, dtype=bool)  #keeps track of nodes that have already flashed this timestep.
        phases += dt #all nodes advance naturally in phase.

        # Cascade loop
        while True:
            new_flash = (phases >= 1.0) & (~flashed)  #Any node with phase >= 1.0 and hasn’t flashed yet.
            if not np.any(new_flash):
                break
            flashed[new_flash] = True
            phases[new_flash] = 0.0
            for idx in np.where(new_flash)[0]:
                phases[neighbors[idx]] += CouplingValue #For each newly flashed node, increment the phases of its neighbors by CouplingValue

        R_t.append(order_parameter(phases))

        if record_states:
            # Save a grayscale frame
            frames.append(phases.reshape(N, M).copy())

    return np.arange(total_steps), np.array(R_t), phases, frames



